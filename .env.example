# Copy to .env and fill in values before first run
# Do NOT commit .env to git

# ── Superuser (used only for init scripts) ───────────────────────────────────
POSTGRES_SUPERUSER=geoff
POSTGRES_SUPERUSER_PASSWORD=changeme

# ── Per-service DB users (created by init scripts) ───────────────────────────
DASHBOARD_DB_USER=dashboard_ro
DASHBOARD_DB_PASSWORD=changeme

AUDIT_DB_USER=audit_writer
AUDIT_DB_PASSWORD=changeme

N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

SCRAPER_DB_USER=scraper
SCRAPER_DB_PASSWORD=changeme

AGENTS_DB_USER=pr_agent
AGENTS_DB_PASSWORD=changeme

CURATOR_DB_USER=curator
CURATOR_DB_PASSWORD=changeme

PODCAST_DB_USER=podcast_agent
PODCAST_DB_PASSWORD=changeme

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=changeme_32chars_minimum_here____
N8N_WEBHOOK_URL=http://localhost:5678

# ── PR Agents ─────────────────────────────────────────────────────────────────
# Model to use for agent reasoning (must be pulled in Ollama first)
AGENT_MODEL=qwen2.5:14b
EMBED_MODEL=nomic-embed-text
# Comma-separated models for concept extraction — each model runs over every chunk independently
# Models not yet pulled are skipped automatically
EXTRACT_MODELS=qwen2.5:14b,deepseek-r1:14b
# Time of day to run the PR crew (HH:MM, 24h, container local time = UTC)
PR_CRON_TIME=07:00
# Set to true to run once immediately on container start (useful for testing)
PR_RUN_ON_START=false

# ── Scraper ───────────────────────────────────────────────────────────────────
# Comma-separated list of "Suburb,STATE" pairs
SCRAPE_SUBURBS=Brisbane,QLD,Ipswich,QLD
SCRAPE_MIN_BEDS=3
SCRAPE_MAX_PRICE=1500000
# Cron schedules (default: scrape every 6h, dedup every 15min)
SCRAPE_CRON=0 */6 * * *
DEDUP_CRON=*/15 * * * *

# ── Whisper ───────────────────────────────────────────────────────────────────
# Options: tiny.en, base.en, small.en, medium.en, large-v3
WHISPER_MODEL=medium.en
